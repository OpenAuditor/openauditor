# .env.example — Next.js + Supabase
# Copy to .env.local for development
# NEVER commit .env.local to version control
# Add .env.local to .gitignore

# =============================================================================
# SUPABASE
# =============================================================================

# Your Supabase project URL — safe to expose to client (NEXT_PUBLIC)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous key — safe to expose to client (NEXT_PUBLIC)
# This key has Row Level Security applied — safe for client-side use
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Supabase service role key — SERVER ONLY, never expose to client
# Used for admin operations that bypass RLS
# NEVER use NEXT_PUBLIC_ prefix for this key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# =============================================================================
# AUTHENTICATION (NextAuth.js / next-auth)
# =============================================================================

# NextAuth URL — used for OAuth callbacks
# In production: set to https://yourdomain.com
# In development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret — used to sign session cookies and JWTs
# Generate with: openssl rand -base64 32
# Must be different in production vs development
NEXTAUTH_SECRET=generate-a-random-secret-here

# =============================================================================
# OAUTH PROVIDERS (add as needed)
# =============================================================================

# GitHub OAuth
# Create at: github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
# Create at: console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# PAYMENTS
# =============================================================================

# Stripe — publishable key (safe to expose to client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe — secret key (SERVER ONLY)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe webhook secret — for verifying webhook signatures
# Get from: dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================================================
# EMAIL
# =============================================================================

# Resend (for transactional email)
# Get at: resend.com/api-keys
RESEND_API_KEY=re_your-api-key

# From email address for transactional emails
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Sentry — error tracking
# Get from: sentry.io/settings/[org]/projects/[project]/keys/
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Logtail — structured log shipping
# Get from: betterstack.com/logs
LOGTAIL_SOURCE_TOKEN=your-logtail-token

# =============================================================================
# RATE LIMITING
# =============================================================================

# Upstash Redis — for rate limiting
# Get from: console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# APPLICATION
# =============================================================================

# Node environment — must be 'production' in production
NODE_ENV=development

# Application URL — used for generating links in emails etc.
APP_URL=http://localhost:3000

# Log level — 'info' for production, 'debug' for development
LOG_LEVEL=debug

# =============================================================================
# NOTES
# =============================================================================
#
# In Vercel, set these via:
#   Dashboard → Project → Settings → Environment Variables
#   Scope each variable to the correct environments (Production/Preview/Development)
#
# Secret variables (anything without NEXT_PUBLIC_):
#   - Set scope: Production + Development
#   - NEVER set NEXT_PUBLIC_ prefix on secrets
#
# Generate secrets:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
