# Node.js + Express Environment Variables Template
# Copy this to .env.local and fill in your values
# Never commit .env files to version control

# =============================================================================
# Server
# =============================================================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# =============================================================================
# Database
# =============================================================================
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/myapp
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/myapp_test
DATABASE_SSL=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# MongoDB (if used)
# MONGODB_URI=mongodb://user:password@localhost:27017/myapp

# Redis (sessions, rate limiting, caching)
REDIS_URL=redis://localhost:6379
# REDIS_TLS_URL=rediss://user:password@redis-host:6380  # for production

# =============================================================================
# Authentication
# =============================================================================
# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-chars-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# For RSA (recommended for distributed systems):
# JWT_PRIVATE_KEY_PATH=./keys/jwt.key
# JWT_PUBLIC_KEY_PATH=./keys/jwt.key.pub

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-minimum-32-chars-change-me
SESSION_NAME=__session
SESSION_MAX_AGE_MS=3600000  # 1 hour

# bcrypt / Argon2 cost factor
PASSWORD_HASH_COST=12

# =============================================================================
# API Security
# =============================================================================
# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Login rate limiting (stricter)
LOGIN_RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
LOGIN_RATE_LIMIT_MAX=5             # 5 attempts

# API key for internal services
INTERNAL_API_KEY=your-internal-api-key-change-me

# =============================================================================
# Email
# =============================================================================
# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postmark
# POSTMARK_SERVER_TOKEN=your-postmark-server-token

# SMTP (generic)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=MyApp

# =============================================================================
# File Storage
# =============================================================================
# AWS S3
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=myapp-uploads
S3_BUCKET_REGION=eu-west-2

# Or Cloudflare R2
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-r2-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=myapp-uploads

# Max upload size in bytes (10MB default)
MAX_UPLOAD_SIZE_BYTES=10485760

# =============================================================================
# Third-Party Services
# =============================================================================
# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+15555550100

# Sentry (error tracking)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# =============================================================================
# Logging and Monitoring
# =============================================================================
LOG_LEVEL=info  # error, warn, info, http, debug
LOG_FORMAT=json  # json or pretty

# Logtail / BetterStack
# LOGTAIL_SOURCE_TOKEN=your-source-token

# Axiom
# AXIOM_TOKEN=your-axiom-token
# AXIOM_DATASET=myapp-logs

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true
MAINTENANCE_MODE=false

# =============================================================================
# Webhook Security
# =============================================================================
# Secret for verifying incoming webhooks
# generate with: openssl rand -base64 32
WEBHOOK_SECRET=your-webhook-secret-change-me

# =============================================================================
# Security
# =============================================================================
# Trusted proxy count (important if behind a load balancer)
# Set to the number of proxy hops before your server
TRUST_PROXY=1

# Content Security Policy report URI (optional)
# CSP_REPORT_URI=https://your-csp-report-endpoint

# HSTS max age in seconds (default 1 year)
HSTS_MAX_AGE=31536000
