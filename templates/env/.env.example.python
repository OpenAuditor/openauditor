# .env.example — Python (FastAPI / Django / Flask)
# Copy to .env for development
# NEVER commit .env to version control
# Add .env to .gitignore

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/your-db-name

# Supabase (if using Supabase as PostgreSQL host)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# =============================================================================
# SECURITY
# =============================================================================

# Django secret key (Django only)
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=generate-a-long-random-secret-key-here

# JWT secret (FastAPI / Flask)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate-a-random-jwt-secret-here

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Allowed origins for CORS
# Comma-separated list
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Allowed hosts (Django)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Environment name — 'production', 'staging', or 'development'
ENVIRONMENT=development

# Debug mode — MUST be False in production
DEBUG=True

# =============================================================================
# PAYMENTS
# =============================================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# =============================================================================
# EMAIL
# =============================================================================

# SMTP settings (or use a transactional email service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com

# Or use Resend:
RESEND_API_KEY=re_your-api-key

# =============================================================================
# STORAGE
# =============================================================================

# AWS S3 (or compatible)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-west-2
S3_BUCKET_NAME=your-bucket-name

# =============================================================================
# REDIS (for caching and rate limiting)
# =============================================================================

REDIS_URL=redis://localhost:6379/0

# Upstash Redis (serverless)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# MONITORING
# =============================================================================

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# THIRD PARTY APIS
# =============================================================================

# OpenAI (if using AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (if using Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# NOTES
# =============================================================================
#
# Loading in Python:
#   pip install python-dotenv
#   from dotenv import load_dotenv
#   load_dotenv()
#   import os
#   database_url = os.environ.get("DATABASE_URL")
#
# Or with Pydantic Settings (recommended for FastAPI):
#   from pydantic_settings import BaseSettings
#   class Settings(BaseSettings):
#       database_url: str
#       jwt_secret_key: str
#       class Config:
#           env_file = ".env"
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
