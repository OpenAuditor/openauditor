# UNIVERSAL GITIGNORE TEMPLATE
# Use this as a baseline for all projects
# Then add language/framework-specific sections from other templates

# ==============================================================================
# CREDENTIALS & SECRETS (CRITICAL - NEVER COMMIT THESE)
# ==============================================================================

# Environment variables
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.staging.local

# API Keys, tokens, credentials
*.key
*.pem
*.p12
*.pfx
*.jks
.secrets
secrets/
credentials/
private_keys/
*.ppk

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts

# OAuth tokens and secrets
oauth_token.txt
access_token.txt
refresh_token.txt

# Database credentials
database.yml
database.local.yml

# AWS credentials
.aws/credentials
.aws/config.local

# Google Cloud
google-cloud-key.json
google-cloud-key-*.json

# Azure credentials
azure-credentials.json

# Third-party API keys
openai_key.txt
anthropic_api_key.txt
huggingface_token.txt

# ==============================================================================
# OPERATING SYSTEM FILES
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*
*~

